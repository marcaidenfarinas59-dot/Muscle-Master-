                    if not choco then isEating = false return end
                    hum:EquipTool(choco)
                    task.wait(0.1)
                    local equipped = char:FindFirstChild(choco.Name)
                    if equipped then
                        equipped:Activate()
                        pcall(function() ChocolateEatEvent:FireServer(equipped) end)
