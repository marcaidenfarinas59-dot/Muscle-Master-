local farmCooldown = {}
local function tryUseFarmMachine(machine)
    local now = tick()
    if (now - (farmCooldown[machine] or 0)) < 0 then return end
    farmCooldown[machine] = now
    pcall(function() machineactive:InvokeServer(machine, true) end)
end

FarmTab:AddSwitch("Auto Farm", function(Value) AutoFarm = Value end)

task.spawn(function()
